# ==============================================================================
# SECTUBE - DOCKER ENVIRONMENT CONFIGURATION
# ==============================================================================
# This file contains environment variables for Docker Compose deployment.
# Copy this to .env and update the values for your production environment.
# ==============================================================================

# ------------------------------------------------------------------------------
# CORE SERVER SETTINGS
# ------------------------------------------------------------------------------
NODE_ENV=production
BACKEND_PORT=5000
FRONTEND_PORT=80
MONGODB_PORT=27017

# Backend URL (internal Docker network)
BACKEND_URL=http://backend:5000

# Frontend URL (external access)
# Update this to your domain in production (e.g., https://yourdomain.com)
FRONTEND_URL=http://localhost

# ------------------------------------------------------------------------------
# FRONTEND BUILD CONFIGURATION
# ------------------------------------------------------------------------------
# Frontend build-time API URL (used by Vite during build)
# Use /api for nginx proxy or http://backend:5000/api for direct access
VITE_API_URL=/api

# ------------------------------------------------------------------------------
# DATABASE (MongoDB)
# ------------------------------------------------------------------------------
MONGODB_URI=mongodb://mongodb:27017/sectube

# ------------------------------------------------------------------------------
# AUTHENTICATION (JWT)
# ------------------------------------------------------------------------------
# IMPORTANT: Generate a strong secret for production using: openssl rand -base64 32
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_EXPIRE=7d

# ------------------------------------------------------------------------------
# OAUTH / SSO (Optional)
# ------------------------------------------------------------------------------
# GitHub Developer Settings - Get from: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google Cloud Console - Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# SECURITY & RATE LIMITING
# ------------------------------------------------------------------------------
# Password Reset Throttling
FORGOT_PASSWORD_LIMIT=3
FORGOT_PASSWORD_WINDOW_MINS=15

# ------------------------------------------------------------------------------
# EMAIL SERVICES (For Password Reset & Alerts)
# ------------------------------------------------------------------------------
# RESEND API (Recommended for cloud platforms like Render)
# Get your API key from: https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100 emails/day
RESEND_API_KEY=

# SMTP (Alternative - works for local development, may be blocked on cloud platforms)
# Use Mailtrap for testing, Brevo/SendGrid for production
SMTP_HOST=
SMTP_PORT=587
SMTP_EMAIL=
SMTP_PASSWORD=

# Email sender info (used by both Resend and SMTP)
FROM_EMAIL=noreply@sectube.com
FROM_NAME=SecTube

# ------------------------------------------------------------------------------
# CLOUD STORAGE (Cloudinary) - Recommended for Production
# ------------------------------------------------------------------------------
# If left blank, the app will use local storage (Docker volumes)
# For production, Cloudinary is recommended for persistent storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ------------------------------------------------------------------------------
# LOCAL FILE STORAGE & PROCESSING (Internal Use)
# ------------------------------------------------------------------------------
# Paths are relative to the backend root (Docker volumes handle persistence)
UPLOAD_PATH=./uploads
VIDEO_PATH=./videos
THUMBNAIL_PATH=./thumbnails

# ------------------------------------------------------------------------------
# UPLOAD CONSTRAINTS (Bytes)
# ------------------------------------------------------------------------------
MAX_VIDEO_SIZE=5368709120
MAX_IMAGE_SIZE=5242880
VIDEO_QUALITIES=360p,480p,720p,1080p

# ------------------------------------------------------------------------------
# AI & MCP CONFIGURATION (OpenRouter)
# ------------------------------------------------------------------------------
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model name from OpenRouter (default: anthropic/claude-3.5-sonnet)
# Available models: https://openrouter.ai/models
# Free models: mistralai/mistral-small-3.1-24b-instruct:free, meta-llama/llama-3.2-3b-instruct:free
CHAT_MODEL=anthropic/claude-3.5-sonnet

# ==============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ==============================================================================
# Before deploying to production:
# 1. Copy this file to .env and update all values
# 2. Generate a strong JWT_SECRET using: openssl rand -base64 32
# 3. Update FRONTEND_URL to your production domain (e.g., https://sectube.com)
# 4. Update VITE_API_URL if using a custom domain (e.g., https://api.sectube.com)
# 5. Set up HTTPS/SSL with a reverse proxy (nginx, Caddy, or Traefik)
# 6. Configure Cloudinary for persistent storage (volumes alone not ideal for production)
# 7. Set up email service (Resend or SMTP) for password resets and notifications
# 8. Configure OAuth providers if using social login (GitHub, Google)
# 9. Set up database backups for MongoDB
# 10. Monitor logs and set up alerting
# 11. Consider adding a CDN for static assets
# 12. Implement rate limiting at the reverse proxy level
# ==============================================================================
