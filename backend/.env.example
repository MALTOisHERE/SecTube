# ==============================================================================
# SECTUBE (CYBERSTREAM) - BACKEND ENVIRONMENT CONFIGURATION
# ==============================================================================

# ------------------------------------------------------------------------------
# CORE SERVER SETTINGS
# ------------------------------------------------------------------------------
PORT=5000
NODE_ENV=development
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# ------------------------------------------------------------------------------
# DATABASE (MongoDB)
# ------------------------------------------------------------------------------
# Local: mongodb://localhost:27017/sectube
# Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/sectube
MONGODB_URI=mongodb://localhost:27017/sectube

# ------------------------------------------------------------------------------
# AUTHENTICATION (JWT)
# ------------------------------------------------------------------------------
# Generate secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars
JWT_EXPIRE=7d

# ------------------------------------------------------------------------------
# OAUTH / SSO (Optional)
# ------------------------------------------------------------------------------
# GitHub Developer Settings
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google Cloud Console
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ------------------------------------------------------------------------------
# SECURITY & RATE LIMITING
# ------------------------------------------------------------------------------
# Password Reset Throttling
FORGOT_PASSWORD_LIMIT=3
FORGOT_PASSWORD_WINDOW_MINS=15

# ------------------------------------------------------------------------------
# EMAIL / SMTP (For Password Reset & Alerts)
# ------------------------------------------------------------------------------
# Use Mailtrap for testing, Brevo/SendGrid for production
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_EMAIL=your_email@example.com
SMTP_PASSWORD=your_smtp_password
FROM_EMAIL=noreply@sectube.com
FROM_NAME=SecTube

# ------------------------------------------------------------------------------
# CLOUD STORAGE (Cloudinary) - Recommended for Production
# ------------------------------------------------------------------------------
# If left blank, the app will attempt to use local storage (less reliable on Render/Vercel)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ------------------------------------------------------------------------------
# LOCAL FILE STORAGE & PROCESSING (Internal Use)
# ------------------------------------------------------------------------------
# Paths are relative to the backend root
UPLOAD_PATH=./uploads
VIDEO_PATH=./videos
THUMBNAIL_PATH=./thumbnails

# FFmpeg paths (Set correctly for your OS)
# Windows example: C:\ffmpeg\bin\ffmpeg.exe
# Linux example: /usr/bin/ffmpeg
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# ------------------------------------------------------------------------------
# UPLOAD CONSTRAINTS (Bytes)
# ------------------------------------------------------------------------------
MAX_VIDEO_SIZE=5368709120
MAX_IMAGE_SIZE=5242880
VIDEO_QUALITIES=360p,480p,720p,1080p

# ==============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ==============================================================================
# 1. Set NODE_ENV=production
# 2. Update FRONTEND_URL to your production domain
# 3. Ensure Cloudinary is configured for persistent video/image assets
# 4. Use a strong, unique JWT_SECRET
# 5. Verify SMTP credentials for account recovery features
# ==============================================================================
